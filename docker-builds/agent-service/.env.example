# Core app
APP_NAME=agent-service
ENVIRONMENT=prod
LOG_LEVEL=INFO

# OpenAI
OPENAI_API_KEY=<set-me>
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=30

# Vikunja
VIKUNJA_BASE_URL=https://tasks.myrobertson.com
VIKUNJA_API_TOKEN=<set-me>
VIKUNJA_PROJECT_ID=1
VIKUNJA_TIMEOUT_SECONDS=20

# Telegram (optional)
TELEGRAM_BOT_TOKEN=<set-me>
TELEGRAM_WEBHOOK_SECRET=<set-me>

# Agent behavior
SESSION_TTL_SECONDS=3600
SESSION_MAX_MESSAGES=20
TOOL_MAX_ITERATIONS=4
AGENT_SYSTEM_PROMPT=You are TaskPilot, a practical personal task assistant.
