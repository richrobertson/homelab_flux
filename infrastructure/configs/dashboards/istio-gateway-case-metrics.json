  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": true,
          "text": "Prometheus",
          "value": "prometheus"
        }
      },
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": {
          "query": "label_values(istio_requests_total{source_workload=\"myrobertson-com-gateway-istio\", reporter=\"source\"}, destination_service_name)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Gateway RPS",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(istio_requests_total{destination_service_name=~\"${service:regex}\",reporter=\"source\", source_workload=\"myrobertson-com-gateway-istio\"}[$__rate_interval]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 200
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "4xx RPS (Upper Bound)",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(istio_requests_total{destination_service_name=~\"${service:regex}\",reporter=\"source\", source_workload=\"myrobertson-com-gateway-istio\",response_code=~\"4..\"}[$__rate_interval]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "5xx RPS (Upper Bound)",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(istio_requests_total{destination_service_name=~\"${service:regex}\",reporter=\"source\", source_workload=\"myrobertson-com-gateway-istio\",response_code=~\"5..\"}[$__rate_interval]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "P95 Latency ms (Upper Bound)",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(istio_request_duration_milliseconds_bucket{destination_service_name=~\"${service:regex}\",reporter=\"source\", source_workload=\"myrobertson-com-gateway-istio\"}[$__rate_interval])))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 400
              },
              {
                "color": "red",
                "value": 1000
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Requests by Service",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (destination_service_name) (rate(istio_requests_total{destination_service_name=~\"${service:regex}\",reporter=\"source\", source_workload=\"myrobertson-com-gateway-istio\"}[$__rate_interval]))",
          "legendFormat": "{{destination_service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "links": [
            {
              "title": "Drilldown: ${__series.name}",
              "url": "/d/istio-gateway-service-drilldown/istio-gateway-service-drilldown?var-service=${__series.name}&${__url_time_range}",
              "targetBlank": false
            }
          ]
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "5xx by Service (Upper Bound)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (destination_service_name) (rate(istio_requests_total{destination_service_name=~\"${service:regex}\",reporter=\"source\", source_workload=\"myrobertson-com-gateway-istio\",response_code=~\"5..\"}[$__rate_interval]))",
          "legendFormat": "{{destination_service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.25
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "links": [
            {
              "title": "Drilldown: ${__series.name}",
              "url": "/d/istio-gateway-service-drilldown/istio-gateway-service-drilldown?var-service=${__series.name}&${__url_time_range}",
              "targetBlank": false
            }
          ]
        }
      }
    }
  ]
}