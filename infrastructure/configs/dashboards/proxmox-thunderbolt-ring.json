        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "rate(node_network_receive_bytes_total{job=\"proxmox-node-exporter\",instance=~\"$node\",device=~\"$interface\"}[$__rate_interval]) * 8 / 1e9",
          "legendFormat": "{{instance}} {{device}} RX",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "rate(node_network_transmit_bytes_total{job=\"proxmox-node-exporter\",instance=~\"$node\",device=~\"$interface\"}[$__rate_interval]) * 8 / 1e9",
          "legendFormat": "{{instance}} {{device}} TX",
          "range": true,
          "refId": "B"
