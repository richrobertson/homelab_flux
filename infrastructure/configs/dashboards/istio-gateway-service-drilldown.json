{
  "title": "Istio Gateway Service Drilldown",
  "uid": "istio-gateway-service-drilldown",
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "graphTooltip": 1,
  "tags": [
    "istio",
    "gateway",
    "drilldown",
    "myrobertson.com"
  ],
  "links": [
    {
      "title": "Back to Gateway Case Metrics",
      "type": "link",
      "url": "/d/istio-gateway-case-metrics/istio-gateway-case-metrics?var-service=All",
      "includeVars": false,
      "keepTime": true,
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": true,
          "text": "Prometheus",
          "value": "prometheus"
        }
      },
      {
        "name": "service",
        "type": "custom",
        "label": "service",
        "query": "authelia,bitwarden.myrobertson.net,gotify.myrobertson.net,immich-server,kermit.myrobertson.net,lidarr,mealie,overseerr,plex.myrobertson.net,prowlarr,radarr,sonarr,syncthing,tautulli.myrobertson.net,trilium.myrobertson.net,whisparr",
        "multi": false,
        "includeAll": false,
        "sort": 0,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "RPS",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(istio_requests_total{destination_service_name=\"$service\",reporter=\"source\", source_workload=\"myrobertson-com-gateway-istio\"}[$__rate_interval]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "4xx RPS (Upper Bound)",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(istio_requests_total{destination_service_name=\"$service\",reporter=\"source\", source_workload=\"myrobertson-com-gateway-istio\",response_code=~\"4..\"}[$__rate_interval]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "5xx RPS (Upper Bound)",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(istio_requests_total{destination_service_name=\"$service\",reporter=\"source\", source_workload=\"myrobertson-com-gateway-istio\",response_code=~\"5..\"}[$__rate_interval]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.2
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "P95 Latency ms (Upper Bound)",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(istio_request_duration_milliseconds_bucket{destination_service_name=\"$service\",reporter=\"source\", source_workload=\"myrobertson-com-gateway-istio\"}[$__rate_interval])))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 300
              },
              {
                "color": "red",
                "value": 800
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Requests by Response Code",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (response_code) (rate(istio_requests_total{destination_service_name=\"$service\",reporter=\"source\", source_workload=\"myrobertson-com-gateway-istio\"}[$__rate_interval]))",
          "legendFormat": "{{response_code}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Latency Percentiles",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "p50",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(istio_request_duration_milliseconds_bucket{destination_service_name=\"$service\",reporter=\"source\", source_workload=\"myrobertson-com-gateway-istio\"}[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "refId": "p95",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(istio_request_duration_milliseconds_bucket{destination_service_name=\"$service\",reporter=\"source\", source_workload=\"myrobertson-com-gateway-istio\"}[$__rate_interval])))",
          "legendFormat": "p95"
        },
        {
          "refId": "p99",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(istio_request_duration_milliseconds_bucket{destination_service_name=\"$service\",reporter=\"source\", source_workload=\"myrobertson-com-gateway-istio\"}[$__rate_interval])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 400
              },
              {
                "color": "red",
                "value": 1000
              }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Request and Response Bytes/sec",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "req",
          "expr": "sum(rate(istio_request_bytes_sum{destination_service_name=\"$service\",reporter=\"source\", source_workload=\"myrobertson-com-gateway-istio\"}[$__rate_interval]))",
          "legendFormat": "request"
        },
        {
          "refId": "resp",
          "expr": "sum(rate(istio_response_bytes_sum{destination_service_name=\"$service\",reporter=\"source\", source_workload=\"myrobertson-com-gateway-istio\"}[$__rate_interval]))",
          "legendFormat": "response"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Success Rate",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(istio_requests_total{destination_service_name=\"$service\",reporter=\"source\", source_workload=\"myrobertson-com-gateway-istio\",response_code!~\"5..\"}[$__rate_interval])) / sum(rate(istio_requests_total{destination_service_name=\"$service\",reporter=\"source\", source_workload=\"myrobertson-com-gateway-istio\"}[$__rate_interval]))",
          "legendFormat": "success"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.98
              },
              {
                "color": "green",
                "value": 0.995
              }
            ]
          }
        }
      }
    }
  ]
}