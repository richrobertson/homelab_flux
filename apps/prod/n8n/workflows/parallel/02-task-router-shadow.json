        "functionCode": "const supported = ['create_task', 'update_task', 'delete_task', 'create_subtask', 'attach_file_to_task'];\nconst intent = $json.intent || 'unknown';\nreturn [{ json: { ...$json, supported: supported.includes(intent), supported_str: supported.includes(intent) ? 'true' : 'false' } }];"
      },
