    {
      "parameters": {
        "functionCode": "const created = $json;\nconst root = $items('Normalize Input', 0, 0)[0].json;\nconst childId = Number(created.id);\nconst parentId = Number(root.parent_task_id || 0);\nif (!parentId || !childId) {\n  throw new Error('create_subtask requires parent_task_id and returned child task id');\n}\nreturn [{ json: { root, child: created, relation_payload: { task_id: parentId, other_task_id: childId, relation_kind: 'subtask' } } }];"
      },
      "id": "build-relation-payload",
      "name": "Build Relation Payload",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
