      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [2240, 280]
    },
    {
      "parameters": {
        "functionCode": "const current = $json;\nconst root = $items('Normalize Input', 0, 0)[0].json;\nconst payload = { ...current };\nif ((root.title || '').trim().length > 0) payload.title = root.title;\nif ((root.description || '').trim().length > 0) payload.description = root.description;\nif ((root.due_date || '').trim().length > 0) payload.due_date = root.due_date;\nif (root.is_done_raw === 'true') payload.done = true;\nif (root.is_done_raw === 'false') payload.done = false;\nreturn [{ json: { task_id: root.task_id, payload } }];"
      },
      "id": "build-update-payload",
      "name": "Build Update Payload",
