      "parameters": {
        "functionCode": "const base64 = ($json.content_base64 || '').trim();\nif (!base64) throw new Error('attach_file_to_task requires content_base64');\nconst taskId = String($json.task_id || '').trim();\nif (!taskId) throw new Error('attach_file_to_task requires task_id');\nreturn [{\n  json: { ...$json },\n  binary: {\n    attachment_file: {\n      data: base64,\n      mimeType: $json.mime_type || 'application/octet-stream',\n      fileName: $json.filename || 'attachment.bin'\n    }\n  }\n}];"
      },
